{
  "name": "dap-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:data": "tsx scripts/generate-daps-json.ts",
    "process:images": "tsx scripts/process-dap-images.ts",
    "discover:daps": "tsx scripts/discovery/discover.ts",
    "discover:daps:ci": "tsx scripts/discovery/discover.ts --no-exit-code",
    "discover:daps:dry-run": "tsx scripts/discovery/discover.ts --dry-run",
    "discover:daps:dedupe": "tsx scripts/discovery/dedupe-issues.ts",
    "test:discovery": "tsx --test scripts/discovery/discovery.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "lucide-vue-next": "^1.0.0",
    "simple-icons": "^16.25.0",
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "sharp": "^0.35.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vue-tsc": "^3.0.0"
  }
}
